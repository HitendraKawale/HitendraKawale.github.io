---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;

const formatted = new Intl.DateTimeFormat("en-US", {
  year: "numeric", month: "long", day: "numeric",
}).format(new Date(frontmatter.date));
---

<BaseLayout
  title={`${frontmatter.title} — Hitendra Kawale`}
  description={frontmatter.description}
>
  <article class="post">
    <header class="post-header">
      <a href="/blog" class="back">← All posts</a>

      <h1>{frontmatter.title}</h1>

      <div class="post-meta">
        <time>{formatted}</time>
        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <div class="tags">
            {frontmatter.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        )}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding: 56px 0 96px;
    max-width: 680px;
  }

  .back {
    display: inline-block;
    font-family: var(--heading);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 36px;
    transition: color 150ms;
  }

  .back:hover { color: var(--accent); }

  h1 {
    font-family: var(--heading);
    font-size: clamp(1.75rem, 4vw, 2.6rem);
    font-weight: 900;
    letter-spacing: 0.04em;
    line-height: 1.15;
    margin-bottom: 18px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    padding-bottom: 40px;
    border-bottom: 2px solid var(--ink);
    margin-bottom: 40px;
  }

  time {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
  }

  .tags { display: flex; gap: 6px; flex-wrap: wrap; }

  .tag {
    font-family: var(--heading);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 3px 10px;
    border: 1px solid var(--border);
    color: var(--muted);
    background: var(--surface);
  }

  /* Prose ─────────────────────── */
  .prose {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #ccc;
  }

  .prose :global(h2) {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
    margin: 48px 0 14px;
  }

  .prose :global(h3) {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin: 32px 0 10px;
  }

  .prose :global(p)  { margin-bottom: 22px; }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 22px;
    margin-bottom: 22px;
  }

  .prose :global(li) { margin-bottom: 6px; }

  .prose :global(strong) { color: var(--text); font-weight: 700; }

  .prose :global(code) {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 2px 7px;
    border-radius: 3px;
    color: var(--accent);
  }

  .prose :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 20px;
    overflow-x: auto;
    margin-bottom: 24px;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--text);
    font-size: 0.875rem;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 18px;
    color: var(--muted);
    margin-bottom: 22px;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 48px 0;
  }
</style>
