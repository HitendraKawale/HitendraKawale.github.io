---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
import { profile } from "../data/profile";

const groups: { label: string; status: typeof projects[0]["status"] }[] = [
  { label: "Built",       status: "Built" },
  { label: "In Progress", status: "In Progress" },
  { label: "Research",    status: "Research" },
];
---

<BaseLayout
  title={`Projects — ${profile.name}`}
  description="Projects by Hitendra Kawale — AI systems, RAG pipelines, LLM evaluation, and computer vision."
>
  <section class="page-header">
    <span class="eyebrow">Work</span>
    <h1>Projects</h1>
    <p>Things I've designed, built, and shipped — or am actively building.</p>
  </section>

  {groups.map(({ label, status }) => {
    const list = projects.filter(p => p.status === status);
    if (!list.length) return null;
    return (
      <section class="group">
        <span class="group-label">{label}</span>
        <div class="grid">
          {list.map(p => <ProjectCard project={p} />)}
        </div>
      </section>
    );
  })}
</BaseLayout>

<style>
  .page-header {
    padding: 72px 0 52px;
    border-bottom: 3px solid var(--ink);
  }

  .eyebrow {
    font-family: var(--heading);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 16px;
  }

  h1 {
    font-family: var(--heading);
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: 0.06em;
    line-height: 1;
    margin-bottom: 16px;
  }

  .page-header p {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 480px;
    line-height: 1.75;
  }

  .group {
    padding: 48px 0;
    border-bottom: 1px solid var(--border);
  }

  .group-label {
    font-family: var(--heading);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
    margin-bottom: 24px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 18px;
  }

  @media (max-width: 560px) {
    .grid { grid-template-columns: 1fr; }
    .group { padding: 36px 0; }
  }
</style>
