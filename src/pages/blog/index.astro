---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";
import { profile } from "../../data/profile";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title={`Blog — ${profile.name}`}
  description="Writing on AI engineering, RAG systems, LLM evaluation, and applied machine learning."
>
  <section class="page-header">
    <span class="eyebrow">Writing</span>
    <h1>Blog</h1>
    <p>Notes on AI engineering, systems thinking, and things I'm building.</p>
  </section>

  <section class="post-section">
    {posts.length === 0 ? (
      <p class="empty">Nothing published yet. Check back soon.</p>
    ) : (
      posts.map(post => <BlogCard post={post} />)
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 72px 0 52px;
    border-bottom: 3px solid var(--ink);
  }

  .eyebrow {
    font-family: var(--heading);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 16px;
  }

  h1 {
    font-family: var(--heading);
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: 0.06em;
    line-height: 1;
    margin-bottom: 16px;
  }

  .page-header p {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 480px;
    line-height: 1.75;
  }

  .post-section {
    padding-bottom: 80px;
  }

  .empty {
    padding: 48px 0;
    color: var(--muted);
    font-size: 1rem;
    border-top: 1px solid var(--border);
  }
</style>
