---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";
import { profile } from "../../data/profile";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title={`Blog — ${profile.name}`}
  description="Writing on AI engineering, RAG systems, LLM evaluation, and applied machine learning."
>
  <section class="page-header">
    <span class="eyebrow">Writing — Dispatches From the Road</span>
    <h1>The Chronicles</h1>
    <p>Notes on AI engineering, systems thinking, and the long struggle of building things that work.</p>
  </section>

  <section class="post-section">
    {posts.length === 0 ? (
      <div class="empty-panel">
        <div class="empty-cap"></div>
        <div class="empty-body">
          <span class="empty-title">No Tales Yet Told</span>
          <span class="empty-sub">The first chapter is still being written. Return soon.</span>
        </div>
        <div class="empty-cap"></div>
      </div>
    ) : (
      posts.map(post => <BlogCard post={post} />)
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 72px 0 52px;
    border-bottom: 3px solid var(--ink);
  }

  .eyebrow {
    font-family: var(--heading);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-hi);
    display: block;
    margin-bottom: 16px;
  }

  h1 {
    font-family: var(--heading);
    font-size: clamp(2.1rem, 5vw, 3.4rem);
    font-weight: 900;
    letter-spacing: 0.06em;
    line-height: 1;
    margin-bottom: 16px;
  }

  .page-header p {
    font-size: 1rem;
    color: var(--muted);
    max-width: 480px;
    line-height: 1.75;
  }

  .post-section {
    padding-bottom: 80px;
  }

  /* ── Empty state ──────────────── */
  .empty-panel {
    margin: 52px 0 96px;
    border: 3px solid var(--ink);
    box-shadow: 4px 4px 0 0 var(--ink);
  }

  .empty-cap {
    height: 24px;
    background-color: var(--ink);
    background-image: radial-gradient(circle, rgba(255,255,255,0.08) 1px, transparent 1px);
    background-size: 5px 5px;
  }

  .empty-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 72px 24px;
    background: var(--surface);
  }

  .empty-title {
    font-family: var(--heading);
    font-size: clamp(1.25rem, 2.6vw, 1.7rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
  }

  .empty-sub {
    font-family: var(--body);
    font-size: 1rem;
    color: var(--muted);
    font-style: italic;
  }
</style>
