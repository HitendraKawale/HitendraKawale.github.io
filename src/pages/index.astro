---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BlogCard from "../components/BlogCard.astro";
import Brand from "../components/Brand.astro";
import { projects } from "../data/projects";
import { profile } from "../data/profile";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const featured = projects.filter(p => p.featured);

// Polyglot line: keep profile order, tag non-fluent levels inline
const main = profile.languages
  .filter(l => l.level !== "Basic")
  .map(l => (l.level === "Conversational" ? `${l.name} (conversational)` : l.name));
const basics = profile.languages.filter(l => l.level === "Basic").map(l => l.name);
const langLine = [...main, `${basics.join(", ")} (basics)`].join(" · ");
---

<BaseLayout
  title={`${profile.name} — ${profile.title}`}
  description={profile.bio}
>

  <!-- ── HERO ────────────────────────────────── -->
  <section class="hero">
    <div class="eclipse" aria-hidden="true"></div>
    <div class="chapter-cap">
      <span class="cap-rule"></span>
      <Brand size={14} />
      <span class="cap-text">Chapter I &nbsp;·&nbsp; The Struggler</span>
      <Brand size={14} />
      <span class="cap-rule"></span>
    </div>
    <div class="hero-grid">

      <div class="hero-left">
        <h1>
          {profile.name.split(" ")[0]}<br />
          {profile.name.split(" ")[1]}
        </h1>
        <p class="epigraph">
          "If you're a struggler — struggle, endure, contend."
          <span class="epigraph-src">— The Skull Knight</span>
        </p>
      </div>

      <div class="hero-right">
        <div class="status-line">
          <span class="dot"></span>
          <span class="status-text">{profile.availability}</span>
        </div>

        <p class="role-tag">{profile.title}</p>
        <p class="bio">{profile.bio}</p>

        <div class="lang-row">
          <span class="lang-label">Polyglot</span>
          <span class="lang-val">{langLine}</span>
        </div>

        <nav class="hero-links">
          <a href={profile.resume} download="Hitendra-Kawale-Resume.pdf" class="resume-link">Resume ↓</a>
          <a href={profile.github} target="_blank" rel="noreferrer">GitHub ↗</a>
          <a href="/contact">Contact</a>
          {profile.linkedin && (
            <a href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn ↗</a>
          )}
        </nav>
      </div>

    </div>
  </section>

  <!-- ── ARSENAL ─────────────────────────────── -->
  <section class="strip">
    <span class="strip-label">Arsenal</span>
    <p class="strip-content">{profile.skills.join(" · ")}</p>
  </section>

  <!-- ── PROJECTS ─────────────────────────────── -->
  {featured.length > 0 && (
    <section class="section">
      <div class="section-head">
        <span class="section-label">Deeds</span>
        <span class="head-rule"></span>
        <a href="/projects" class="section-more">The full armoury ↗</a>
      </div>
      <div class="project-grid">
        {featured.map(p => <ProjectCard project={p} />)}
      </div>
    </section>
  )}

  <!-- ── WRITING ───────────────────────────────── -->
  {posts.length > 0 && (
    <section class="section">
      <div class="section-head">
        <span class="section-label">Chronicles</span>
        <span class="head-rule"></span>
        <a href="/blog" class="section-more">All chronicles ↗</a>
      </div>
      <div>
        {posts.map(post => <BlogCard post={post} />)}
      </div>
    </section>
  )}

</BaseLayout>

<style>
  /* ── Chapter caption ──────────── */
  .chapter-cap {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 0 0;
  }

  .cap-rule {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .cap-text {
    font-family: var(--heading);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-hi);
    white-space: nowrap;
  }

  /* ── Hero ─────────────────────── */
  .hero {
    padding: 32px 0 72px;
    border-bottom: 3px solid var(--ink);
    position: relative;
  }

  /* The Eclipse — looming behind the name */
  .eclipse {
    position: absolute;
    width: min(560px, 90vw);
    aspect-ratio: 1;
    left: min(-60px, -4vw);
    top: -20px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      transparent 39%,
      rgba(139, 26, 26, 0.5) 46%,
      rgba(192, 57, 43, 0.16) 53%,
      transparent 63%
    );
    filter: blur(5px);
    animation: eclipsePulse 7s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes eclipsePulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.03); }
  }

  .hero-grid, .chapter-cap { position: relative; }

  .epigraph {
    font-family: var(--body);
    font-style: italic;
    font-size: 1rem;
    color: var(--muted);
    margin-top: 24px;
    max-width: 360px;
    line-height: 1.7;
  }

  .epigraph-src {
    display: block;
    font-family: var(--heading);
    font-style: normal;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent-hi);
    margin-top: 8px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 48px;
    align-items: center;
    padding-top: 40px;
  }

  h1 {
    font-family: var(--heading);
    font-size: clamp(3rem, 7.5vw, 5.2rem);
    font-weight: 900;
    letter-spacing: 0.04em;
    line-height: 0.92;
    color: var(--text);
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .status-line {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
    animation: blink 2.5s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.25; }
  }

  .status-text {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--green);
    letter-spacing: 0.06em;
  }

  .role-tag {
    font-family: var(--heading);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .bio {
    font-size: 0.98rem;
    color: var(--muted);
    line-height: 1.8;
  }

  .lang-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .lang-label {
    font-family: var(--heading);
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .lang-val {
    font-size: 0.9rem;
    color: var(--text);
  }

  .hero-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .hero-links a {
    font-family: var(--heading);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    padding-bottom: 3px;
    transition: color 150ms, border-color 150ms;
  }

  .hero-links a:hover {
    color: var(--accent-hi);
    border-color: var(--accent);
  }

  .hero-links .resume-link {
    color: var(--accent-hi);
    border-color: var(--accent);
  }

  .hero-links .resume-link:hover {
    color: var(--text);
    border-color: var(--text);
  }

  @media (max-width: 680px) {
    .hero { padding: 24px 0 52px; }
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 36px;
      padding-top: 32px;
    }
    h1 { font-size: clamp(2.6rem, 11vw, 3.8rem); }
  }

  /* ── Stack strip ──────────────── */
  .strip {
    padding: 18px 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: 20px;
    flex-wrap: wrap;
  }

  .strip-label {
    font-family: var(--heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent-hi);
    flex-shrink: 0;
  }

  .strip-content {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.9;
  }

  /* ── Sections ─────────────────── */
  .section {
    padding: 56px 0;
    border-bottom: 1px solid var(--border);
  }

  .section-head {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }

  .head-rule {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .section-label {
    font-family: var(--heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--accent-hi);
  }

  .section-more {
    font-family: var(--heading);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 150ms;
  }

  .section-more:hover { color: var(--text); }

  /* ── Projects grid ────────────── */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 18px;
  }

  @media (max-width: 620px) {
    .project-grid { grid-template-columns: 1fr; }
    .section { padding: 40px 0; }
  }
</style>
