---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Section from "../components/Section.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Hitendra Kawale — AI Engineer"
  description="AI engineer building production-style ML systems, RAG platforms, LLM evaluation tooling, and applied computer vision projects."
>
  <section class="hero">
    <p class="eyebrow">AI Engineer · Backend Systems · Applied ML</p>

    <h1>I build AI systems that connect models, data, APIs, and real product workflows.</h1>

    <p class="intro">
      I work across RAG, LLM evaluation, backend infrastructure, computer vision,
      and production-style machine learning systems.
    </p>

    <div class="hero-links">
      <a href="#projects">View projects</a>
      <a href="https://github.com/HitendraKawale" target="_blank" rel="noreferrer">
        GitHub
      </a>
      <a href="#contact">Contact</a>
    </div>
  </section>

  <Section
    id="projects"
    eyebrow="Selected Work"
    title="Projects built around real AI engineering problems."
  >
    <div class="project-list">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </Section>

  <section id="focus" class="focus-section">
    <div>
      <p class="eyebrow">Technical Focus</p>
      <h2>Where I am strongest.</h2>
    </div>

    <ul>
      <li>FastAPI backend systems for AI products</li>
      <li>RAG pipelines, vector search, embeddings, and retrieval workflows</li>
      <li>LLM evaluation, prompt testing, and model comparison tooling</li>
      <li>Applied computer vision and 3D Gaussian Splatting research</li>
      <li>Docker, observability, CI checks, and deployment-minded engineering</li>
    </ul>
  </section>

  <section id="contact" class="contact-section">
    <p class="eyebrow">Contact</p>
    <h2>Open to AI engineering and applied ML roles.</h2>
    <p>
      The best place to start is my GitHub. Resume and project case studies will
      be added as this site evolves.
    </p>

    <a href="https://github.com/HitendraKawale" target="_blank" rel="noreferrer">
      github.com/HitendraKawale
    </a>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 96px 0 88px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 860px;
    margin: 0;
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.08em;
  }

  .intro {
    max-width: 660px;
    margin: 28px 0 0;
    color: var(--muted);
    font-size: 1.2rem;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .hero-links a,
  .contact-section a {
    display: inline-flex;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 10px 16px;
    background: rgba(255, 255, 255, 0.5);
  }

  .hero-links a:hover,
  .contact-section a:hover {
    border-color: var(--text);
  }

  .project-list {
    display: grid;
    gap: 18px;
  }

  .focus-section,
  .contact-section {
    padding: 72px 0;
    border-top: 1px solid var(--border);
  }

  .focus-section {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 48px;
  }

  .focus-section h2,
  .contact-section h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  ul {
    margin: 0;
    padding-left: 20px;
    color: var(--muted);
    line-height: 1.9;
  }

  .contact-section p {
    max-width: 640px;
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .hero {
      padding: 64px 0;
    }

    .focus-section {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 56px 0;
    }

    .contact-section {
      padding: 56px 0;
    }
  }
</style>
