---
interface Props {
  id?: string;
  eyebrow: string;
  title: string;
}

const { id, eyebrow, title } = Astro.props;
---

<section id={id} class="section">
  <div class="section-heading">
    <p>{eyebrow}</p>
    <h2>{title}</h2>
  </div>

  <slot />
</section>

<style>
  .section {
    padding: 72px 0;
    border-top: 1px solid var(--border);
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 32px;
  }

  .section-heading p {
    margin: 0 0 18px;
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  @media (max-width: 760px) {
    .section {
      padding: 56px 0;
    }
  }
</style>
