---
import Brand from "./Brand.astro";
const { pathname } = Astro.url;
---

<header class="nav-wrap">
  <nav class="nav container">
    <a href="/" class="brand" title="The Struggler">
      <Brand size={26} />
      <span class="brand-text">泽贤</span>
    </a>

    <div class="nav-links">
      <a href="/projects" class:list={["nl", { active: pathname.startsWith("/projects") }]}>
        Armoury
      </a>
      <a href="/blog" class:list={["nl", { active: pathname.startsWith("/blog") }]}>
        Chronicles
      </a>
      <a href="/contact" class:list={["nl-cta", { active: pathname === "/contact" }]}>
        Send Word
      </a>
    </div>
  </nav>
</header>

<style>
  .nav-wrap {
    border-bottom: 3px solid var(--ink);
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13, 11, 8, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* Thin blood line under the ink border */
  .nav-wrap::after {
    content: '';
    display: block;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent) 30%, var(--accent) 70%, transparent);
    opacity: 0.55;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-h);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .brand:hover :global(.brand-mark) {
    filter: drop-shadow(0 0 8px rgba(192, 57, 43, 0.9));
  }

  .brand :global(.brand-mark) {
    transition: filter 200ms;
  }

  .brand-text {
    font-family: 'Noto Serif SC', 'STSong', 'SimSun', serif;
    font-size: 1.3rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    color: var(--text);
    line-height: 1;
    transition: color 150ms;
  }

  .brand:hover .brand-text { color: var(--accent-hi); }

  .nav-links {
    display: flex;
    align-items: center;
  }

  .nl {
    font-family: var(--heading);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 8px 16px;
    transition: color 150ms;
    border-bottom: 2px solid transparent;
    margin-bottom: -3px;
  }

  .nl:hover, .nl.active {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  .nl-cta {
    font-family: var(--heading);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 7px 16px;
    margin-left: 12px;
    border: 2px solid var(--border);
    color: var(--text);
    transition: border-color 150ms, color 150ms, background 150ms;
  }

  .nl-cta:hover, .nl-cta.active {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(139, 26, 26, 0.08);
  }

  @media (max-width: 500px) {
    .nl-cta { display: none; }
    .brand-text { font-size: 1.15rem; }
  }
</style>
