---
import { profile } from "../data/profile";
const { pathname } = Astro.url;
---

<header class="nav-wrap">
  <nav class="nav container">
    <a href="/" class="brand">
      <span class="brand-text">HK</span>
      <span class="brand-bar"></span>
    </a>

    <div class="nav-links">
      <a href="/projects" class:list={["nl", { active: pathname.startsWith("/projects") }]}>
        Projects
      </a>
      <a href="/blog" class:list={["nl", { active: pathname.startsWith("/blog") }]}>
        Blog
      </a>
      <a href={`mailto:${profile.email}`} class="nl-cta">
        Get in touch
      </a>
    </div>
  </nav>
</header>

<style>
  .nav-wrap {
    border-bottom: 3px solid var(--ink);
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13, 11, 8, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-h);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    transition: opacity 150ms;
  }

  .brand:hover { opacity: 0.7; }

  .brand-text {
    font-family: var(--heading);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--text);
  }

  .brand-bar {
    width: 18px;
    height: 2px;
    background: var(--accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
  }

  .nl {
    font-family: var(--heading);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 8px 16px;
    transition: color 150ms;
    border-bottom: 2px solid transparent;
    margin-bottom: -3px;
  }

  .nl:hover, .nl.active {
    color: var(--text);
    border-bottom-color: var(--accent);
  }

  .nl-cta {
    font-family: var(--heading);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 7px 16px;
    margin-left: 12px;
    border: 2px solid var(--border);
    color: var(--text);
    transition: border-color 150ms, color 150ms, background 150ms;
  }

  .nl-cta:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(139, 26, 26, 0.08);
  }

  @media (max-width: 500px) {
    .nl-cta { display: none; }
    .brand-bar { display: none; }
  }
</style>
