---
import { profile } from "../data/profile";
const { pathname } = Astro.url;
---

<header class="nav-wrap">
  <nav class="nav container">
    <a href="/" class="brand">HK</a>

    <div class="nav-links">
      <a href="/projects" class:list={["nl", { active: pathname.startsWith("/projects") }]}>
        Projects
      </a>
      <a href="/blog" class:list={["nl", { active: pathname.startsWith("/blog") }]}>
        Blog
      </a>
      <a href={`mailto:${profile.email}`} class="nl-cta">
        Get in touch
      </a>
    </div>
  </nav>
</header>

<style>
  .nav-wrap {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(11, 11, 11, 0.9);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-h);
  }

  .brand {
    font-family: var(--mono);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--text);
    transition: color 150ms;
  }

  .brand:hover {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .nl {
    font-size: 0.875rem;
    color: var(--muted);
    padding: 6px 12px;
    border-radius: 4px;
    transition: color 150ms;
  }

  .nl:hover, .nl.active {
    color: var(--text);
  }

  .nl-cta {
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 7px 16px;
    margin-left: 8px;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    transition: border-color 150ms, color 150ms;
  }

  .nl-cta:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  @media (max-width: 500px) {
    .nl-cta { display: none; }
  }
</style>
