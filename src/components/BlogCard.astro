---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const formatted = new Intl.DateTimeFormat("en-US", {
  year: "numeric", month: "short", day: "numeric",
}).format(new Date(post.data.date));
---

<a class="post-row" href={`/blog/${post.id}`}>
  <time>{formatted}</time>
  <div class="post-info">
    <h3>{post.data.title}</h3>
    <p>{post.data.description}</p>
  </div>
  <span class="arrow">↗</span>
</a>

<style>
  .post-row {
    display: grid;
    grid-template-columns: 110px 1fr 24px;
    align-items: start;
    gap: 24px;
    padding: 22px 0;
    border-bottom: 1px solid var(--border);
    transition: color 150ms;
    position: relative;
  }

  /* Ink bar slides in from left on hover */
  .post-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0;
    background: var(--accent);
    transition: width 200ms ease;
  }

  .post-row:hover::before { width: 3px; }

  .post-row:first-child { border-top: 1px solid var(--border); }

  time {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--muted);
    padding-top: 3px;
    white-space: nowrap;
  }

  h3 {
    font-family: var(--heading);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    margin-bottom: 5px;
    color: var(--text);
    transition: color 150ms;
  }

  .post-row:hover h3 { color: var(--accent-hi); }

  p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .arrow {
    font-size: 1rem;
    color: var(--muted);
    transition: color 150ms, transform 150ms;
    padding-top: 2px;
  }

  .post-row:hover .arrow {
    color: var(--accent-hi);
    transform: translate(2px, -2px);
  }

  @media (max-width: 560px) {
    .post-row {
      grid-template-columns: 1fr 20px;
      gap: 12px;
    }
    time {
      grid-column: 1 / -1;
      margin-bottom: -8px;
    }
  }
</style>
