---
import { profile } from "../data/profile";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="sigil">ᛟ</span>
      <span class="copy">{profile.name} · {year}</span>
    </div>
    <div class="links">
      <a href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
      {profile.linkedin && (
        <a href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      )}
      <a href={`mailto:${profile.email}`}>Email</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    border-top: 3px solid var(--ink);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 0;
    flex-wrap: wrap;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .sigil {
    font-size: 1rem;
    color: var(--accent);
    opacity: 0.7;
    line-height: 1;
  }

  .copy {
    font-family: var(--heading);
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .links {
    display: flex;
    gap: 20px;
  }

  .links a {
    font-family: var(--heading);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 150ms;
  }

  .links a:hover {
    color: var(--accent);
  }
</style>
