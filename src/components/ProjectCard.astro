---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;

const statusColor: Record<Project["status"], string> = {
  "Built":       "#22c55e",
  "In Progress": "#f97316",
  "Research":    "#818cf8",
};
---

<article class="card">
  <header class="card-top">
    <span class="status" style={`color: ${statusColor[project.status]}`}>
      {project.status}
    </span>
    <span class="subtitle">{project.subtitle}</span>
  </header>

  <h3>{project.title}</h3>
  <p class="desc">{project.description}</p>

  <div class="stack">
    {project.stack.map(t => <span class="pill">{t}</span>)}
  </div>

  {project.href && (
    <a class="clink" href={project.href} target="_blank" rel="noreferrer">
      View project ↗
    </a>
  )}
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: border-color 200ms;
  }

  .card:hover {
    border-color: var(--accent);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .status {
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .subtitle {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: right;
  }

  h3 {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
  }

  .desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .pill {
    font-family: var(--mono);
    font-size: 0.7rem;
    padding: 3px 9px;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--muted);
    background: var(--surface-2);
  }

  .clink {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--muted);
    width: fit-content;
    transition: color 150ms;
    margin-top: 4px;
  }

  .clink:hover {
    color: var(--accent);
  }

  @media (max-width: 560px) {
    .card-top { flex-direction: column; align-items: flex-start; }
    .subtitle { text-align: left; }
  }
</style>
