---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;

const statusColor: Record<Project["status"], string> = {
  "Built": "#16a34a",
  "Research": "#2563eb",
  "In Progress": "#d97706",
};
---

<article class="card">
  <div class="card-top">
    <span class="status" style={`color: ${statusColor[project.status]}`}>
      {project.status}
    </span>
    <span class="subtitle">{project.subtitle}</span>
  </div>

  <div class="card-body">
    <h3>{project.title}</h3>
    <p>{project.description}</p>
  </div>

  <div class="stack" aria-label="Tech stack">
    {project.stack.map(item => <span class="pill">{item}</span>)}
  </div>

  {project.href && (
    <a class="card-link" href={project.href} target="_blank" rel="noreferrer">
      View project ↗
    </a>
  )}
</article>

<style>
  .card {
    display: grid;
    gap: 18px;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg);
    transition: border-color 150ms, transform 150ms;
  }

  .card:hover {
    border-color: #c0c0c0;
    transform: translateY(-1px);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .status {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .subtitle {
    font-size: 0.85rem;
    color: var(--muted);
    text-align: right;
  }

  .card-body h3 {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
  }

  .card-body p {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .pill {
    font-size: 0.78rem;
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 99px;
    color: var(--muted);
    background: var(--surface);
  }

  .card-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
    width: fit-content;
    transition: opacity 150ms;
  }

  .card-link:hover {
    opacity: 0.6;
  }

  @media (max-width: 560px) {
    .card-top {
      flex-direction: column;
      align-items: flex-start;
    }
    .subtitle {
      text-align: left;
    }
  }
</style>
