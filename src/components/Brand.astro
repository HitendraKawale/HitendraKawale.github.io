---
// The Brand of Sacrifice — the site sigil, traced from the canonical mark:
// crowned central shaft, two bent cross-arms, hollow diamond. Colored via
// `currentColor` so the parent sets it (defaults to blood red).
interface Props {
  size?: number;
  class?: string;
}
const { size = 20, class: className = "" } = Astro.props;
---

<svg
  class:list={["brand-mark", className]}
  width={size * (70 / 120)}
  height={size}
  viewBox="0 0 70 120"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <!-- shaft + crown + cross-arms (nonzero fill, overlaps merge) -->
  <path
    fill="currentColor"
    d="M35 0 L37 8.5 L33 8.5 Z
       M29.8 4.5 L33.5 9 L31.5 10.5 Z
       M40.2 4.5 L38.5 10.5 L36.5 9 Z
       M31 7.5 L39 7.5 L37.5 12 L32.5 12 Z
       M32.5 9 L37.5 9 L37.5 108 L35 118 L32.5 108 Z
       M17 10 L0.5 24 L0.5 29 L38 60 L40.5 53.5 L8.5 27 Z
       M53 10 L61.5 27 L29.5 53.5 L32 60 L69.5 29 L69.5 24 Z"
  />
  <!-- hollow diamond ring -->
  <path
    fill="currentColor"
    fill-rule="evenodd"
    d="M35 47 L69.5 84 L35 118 L0.5 84 Z
       M35 60 L58 84 L35 106 L12 84 Z"
  />
</svg>

<style>
  .brand-mark {
    color: var(--accent);
    flex-shrink: 0;
    filter: drop-shadow(0 0 4px rgba(192, 57, 43, 0.45));
  }
</style>
